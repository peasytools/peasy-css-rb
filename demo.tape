# peasy-css-rb — CSS minify, format, analyze (Ruby)
# Theme: Dracula
# Generated for AgentGIF demo collection

Output demo.gif
Set Shell "zsh"
Set Theme "Dracula"
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set TypingSpeed 50ms

# Show package info
Type "# peasy-css-rb — CSS minify, format, analyze for Ruby"
Enter
Type "# peasycss.com"
Enter
Sleep 500ms

# Run the demo
Type "ruby -I lib examples/demo.rb"
Enter
Sleep 5s
